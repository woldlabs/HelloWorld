# =============================================================================
# .gitignore for WoldLabs HelloWorld (x86-64 Assembly)
# =============================================================================

# Build artifacts from NASM + ld
*.o
hello
hello.exe

# Python artifacts (from previous versions of this project)
__pycache__/
*.py[cod]
*$py.class

# Common editor / IDE noise
.idea/
.vscode/
*.swp
*~

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log

# Virtual environments (kept for historical completeness)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
